<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.janpricechecker.mapper.ProductPriceMapper">

  <resultMap id="ProductResultMap" type="com.example.janpricechecker.dto.ProductDto">
    <constructor>
      <idArg column="id" javaType="java.lang.Long"/>
      <arg column="jan_code" javaType="java.lang.String"/>
      <arg column="name" javaType="java.lang.String"/>
    </constructor>
  </resultMap>

  <resultMap id="PriceResultMap" type="com.example.janpricechecker.dto.PriceDto">
    <constructor>
      <arg column="shop_name" javaType="java.lang.String"/>
      <arg column="price_yen" javaType="java.lang.Integer"/>
      <arg column="fetched_at" javaType="java.time.OffsetDateTime"/>
    </constructor>
  </resultMap>

  <select id="findProductByJanCode" parameterType="string" resultMap="ProductResultMap">
    SELECT id, jan_code, name
    FROM products
    WHERE jan_code = #{janCode}
  </select>

  <select id="findLatestPricesByProductId" parameterType="long" resultMap="PriceResultMap">
    SELECT
      s.name AS shop_name,
      pp.price_yen,
      pp.fetched_at
    FROM purchase_prices pp
    INNER JOIN shops s ON s.id = pp.shop_id
    WHERE pp.product_id = #{productId}
    ORDER BY pp.price_yen DESC
  </select>

</mapper>
